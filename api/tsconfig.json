{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@footy-scores/shared": ["../shared/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
  },
  "exclude": ["node_modules"]
}
